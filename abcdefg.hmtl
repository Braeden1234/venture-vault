<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Scout Master</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:            #0e0e10;
      --surface:       #18181b;
      --surface2:      #222226;
      --surface3:      #2a2a2f;
      --border:        rgba(255,255,255,0.08);
      --border-strong: rgba(255,255,255,0.16);
      --text:          #f4f4f5;
      --text2:         #a1a1aa;
      --text3:         #52525b;
      --accent:        #3b82f6;
      --accent-soft:   rgba(59,130,246,0.15);
      --green:         #22c55e;
      --green-soft:    rgba(34,197,94,0.12);
      --red-c:         #ef4444;
      --red-soft:      rgba(239,68,68,0.12);
      --yellow:        #f59e0b;
      --yellow-soft:   rgba(245,158,11,0.12);
      --left-w:        296px;
    }
    html,body{height:100%;overflow:hidden;}
    body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg);color:var(--text);display:flex;flex-direction:column;}

    .topbar{background:var(--surface);border-bottom:1px solid var(--border);height:52px;display:flex;align-items:center;flex-shrink:0;position:relative;z-index:200;}
    .topbar-brand{padding:0 18px;font-size:14px;font-weight:700;letter-spacing:-0.02em;white-space:nowrap;flex-shrink:0;border-right:1px solid var(--border);}
    .topbar-brand span{color:var(--accent);}
    .tab-strip{display:flex;align-items:stretch;height:100%;border-right:1px solid var(--border);}
    .tab{padding:0 18px;font-size:12.5px;font-weight:500;cursor:pointer;display:flex;align-items:center;gap:7px;color:var(--text3);border-bottom:2px solid transparent;transition:color .12s,border-color .12s;white-space:nowrap;user-select:none;}
    .tab:hover{color:var(--text2);}
    .tab.active{color:var(--text);border-bottom-color:var(--accent);}
    .tab-dot{width:6px;height:6px;border-radius:50%;background:var(--text3);flex-shrink:0;transition:background .12s;}
    .tab.active .tab-dot{background:var(--accent);}
    .tab-ct{font-size:10px;color:var(--text3);background:var(--surface2);border-radius:4px;padding:1px 6px;margin-left:2px;}
    .topbar-meta{flex:1;padding:0 14px;font-size:12px;color:var(--text3);overflow:hidden;white-space:nowrap;text-overflow:ellipsis;}
    .topbar-actions{display:flex;gap:7px;padding:0 14px;flex-shrink:0;}

    .btn{height:30px;padding:0 13px;border-radius:6px;font-size:12px;font-weight:600;border:1px solid var(--border-strong);background:var(--surface2);color:var(--text);cursor:pointer;white-space:nowrap;display:inline-flex;align-items:center;gap:5px;transition:background .1s,opacity .1s;flex-shrink:0;}
    .btn:hover{background:var(--surface3);}
    .btn:disabled{opacity:.38;cursor:not-allowed;}
    .btn.accent{background:var(--accent);border-color:var(--accent);color:#fff;}
    .btn.accent:hover{opacity:.85;}
    .btn.green{background:var(--green);border-color:var(--green);color:#000;font-weight:700;}
    .btn.green:hover{opacity:.85;}
    .btn.danger:hover{background:var(--red-soft);border-color:var(--red-c);color:var(--red-c);}

    .layout{display:flex;flex:1;min-height:0;}

    .left-panel{width:var(--left-w);flex-shrink:0;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow-y:auto;}
    .lp-sec{padding:15px;border-bottom:1px solid var(--border);flex-shrink:0;}
    .lp-ttl{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);margin-bottom:11px;}
    .lp-f{display:flex;flex-direction:column;gap:4px;margin-bottom:7px;}
    .lp-f:last-child{margin-bottom:0;}
    .lp-lbl{font-size:11px;color:var(--text3);font-weight:500;}
    .lp-i{height:31px;padding:0 9px;border:1px solid var(--border-strong);border-radius:7px;font-size:12.5px;color:var(--text);background:var(--surface2);outline:none;width:100%;transition:border-color .12s;}
    .lp-i:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-soft);}

    .match-big{background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:11px;text-align:center;margin-bottom:9px;}
    .mb-lbl{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);margin-bottom:2px;}
    .mb-num{font-size:46px;font-weight:800;line-height:1;letter-spacing:-.04em;color:var(--text);}
    .mb-sub{font-size:11px;color:var(--text3);margin-top:3px;}
    .match-nav{display:flex;gap:6px;}
    .match-nav .btn{flex:1;justify-content:center;height:34px;font-size:12px;}

    .pill{font-size:11.5px;padding:7px 9px;border-radius:7px;margin-top:7px;display:none;line-height:1.5;}
    .pill.ok{display:block;background:var(--green-soft);color:var(--green);border:1px solid rgba(34,197,94,.2);}
    .pill.err{display:block;background:var(--red-soft);color:var(--red-c);border:1px solid rgba(239,68,68,.2);}
    .pill.pending{display:block;background:var(--yellow-soft);color:var(--yellow);border:1px solid rgba(245,158,11,.2);}

    .lnk-list{display:flex;flex-direction:column;gap:5px;}
    .lnk-row{display:flex;align-items:center;gap:6px;padding:7px 9px;border-radius:7px;border:1px solid var(--border);background:var(--surface2);}
    .al-badge{font-size:9px;font-weight:700;letter-spacing:.05em;padding:2px 6px;border-radius:4px;white-space:nowrap;flex-shrink:0;}
    .al-badge.red{background:rgba(239,68,68,.15);color:#f87171;}
    .al-badge.blue{background:rgba(59,130,246,.15);color:#60a5fa;}
    .lnk-team{font-size:13px;font-weight:700;flex:1;color:var(--text);}
    .lnk-name{font-size:11px;color:var(--text3);flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .ico-btn{width:22px;height:22px;border-radius:4px;border:1px solid var(--border);background:transparent;color:var(--text3);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .1s;flex-shrink:0;}
    .ico-btn:hover{background:var(--surface3);color:var(--text);}

    .main-area{flex:1;display:flex;flex-direction:column;min-height:0;overflow:hidden;}
    .tab-panel{display:none;flex:1;overflow:hidden;flex-direction:column;}
    .tab-panel.active{display:flex;}

    .sch-wrap{flex:1;overflow-y:auto;padding:18px 20px;}
    .sch-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:13px;}
    .sch-title{font-size:14px;font-weight:700;}
    .sch-meta{font-size:12px;color:var(--text3);}
    .tbl-wrap{overflow-x:auto;}
    table{width:100%;border-collapse:collapse;font-size:12.5px;}
    thead th{background:var(--surface);padding:7px 11px;font-size:10px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--text3);border-bottom:1px solid var(--border);text-align:left;white-space:nowrap;}
    thead th.red{color:#f87171;}thead th.blue{color:#60a5fa;}
    tbody tr{border-bottom:1px solid var(--border);transition:background .07s;}
    tbody tr:hover{background:var(--surface2);}
    tbody tr.cur{background:rgba(59,130,246,.08)!important;box-shadow:inset 2px 0 0 var(--accent);}
    tbody td{padding:7px 11px;}
    td.mn{font-weight:700;color:var(--text2);width:48px;}
    td.rt{color:#fca5a5;font-weight:600;}td.bt{color:#93c5fd;font-weight:600;}
    .tn{font-size:10px;color:var(--text3);display:block;margin-top:1px;font-weight:400;}
    .go-btn{height:23px;padding:0 9px;border-radius:4px;font-size:11px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--text3);cursor:pointer;transition:all .1s;white-space:nowrap;}
    .go-btn:hover,.go-btn.cur{background:var(--accent);border-color:var(--accent);color:#fff;}
    .empty-state{padding:60px 20px;text-align:center;color:var(--text3);font-size:13px;line-height:1.9;}
    .empty-icon{font-size:34px;margin-bottom:11px;opacity:.35;}

    .builder-layout{flex:1;display:flex;min-height:0;overflow:hidden;}
    .palette{width:152px;flex-shrink:0;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;padding:11px 7px 14px;gap:2px;overflow-y:auto;}
    .pal-lbl{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);padding:0 4px;margin-bottom:4px;}
    .pal-btn{display:flex;align-items:center;gap:6px;padding:7px;border-radius:6px;border:1px solid transparent;cursor:pointer;font-size:12px;color:var(--text2);background:transparent;width:100%;text-align:left;transition:all .1s;user-select:none;}
    .pal-btn:hover{background:var(--surface2);border-color:var(--border);color:var(--text);}
    .pal-btn svg{flex-shrink:0;opacity:.7;}
    .pal-ct{margin-left:auto;font-size:10px;color:var(--text3);background:var(--surface2);border-radius:3px;padding:1px 5px;min-width:16px;text-align:center;}
    .pal-div{height:1px;background:var(--border);margin:6px 0;}
    .pal-tip{font-size:10px;color:var(--text3);padding:0 4px;line-height:1.7;}
    .reorder-toggle{display:flex;align-items:center;gap:6px;padding:6px 7px;border-radius:6px;border:1px solid var(--border);font-size:11px;color:var(--text3);background:var(--surface2);width:100%;cursor:pointer;transition:all .1s;user-select:none;}
    .reorder-toggle:hover{border-color:var(--border-strong);color:var(--text2);}
    .reorder-toggle.on{background:var(--accent-soft);border-color:var(--accent);color:var(--accent);}
    .rt-dot{width:6px;height:6px;border-radius:50%;background:var(--text3);flex-shrink:0;}
    .reorder-toggle.on .rt-dot{background:var(--accent);}

    .load-form-btn{display:flex;align-items:center;gap:6px;padding:6px 7px;border-radius:6px;border:1px solid var(--border);font-size:11px;color:var(--text3);background:var(--surface2);width:100%;cursor:pointer;transition:all .1s;user-select:none;text-align:left;}
    .load-form-btn:hover:not(:disabled){border-color:var(--accent);color:var(--accent);background:var(--accent-soft);}
    .load-form-btn:disabled{opacity:.38;cursor:not-allowed;}
    .schema-status{font-size:10px;padding:5px 7px;border-radius:5px;margin-top:1px;display:none;line-height:1.5;}
    .schema-status.ok{display:block;background:var(--green-soft);color:var(--green);}
    .schema-status.err{display:block;background:var(--red-soft);color:var(--red-c);}
    .schema-status.pending{display:block;background:var(--yellow-soft);color:var(--yellow);}

    .canvas-wrap{flex:1;overflow-y:auto;padding:16px 18px 80px;}
    .bldr-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:11px;}
    .bldr-title{font-size:13px;font-weight:600;}
    .bldr-ct{font-size:11px;color:var(--text3);}
    #canvas-empty{border:1.5px dashed var(--border-strong);border-radius:9px;padding:40px 18px;text-align:center;color:var(--text3);font-size:13px;line-height:1.8;transition:border-color .14s,background .14s;pointer-events:none;}
    #canvas-empty.drag-hi{border-color:var(--accent);background:var(--accent-soft);color:var(--accent);}
    #canvas{display:flex;flex-direction:column;}

    .mod{background:var(--surface);border:1px solid var(--border);border-radius:9px;padding:12px 13px 13px;margin-bottom:6px;position:relative;transition:opacity .15s;}
    .mod.is-dragging{opacity:.22;}
    .mod.will-drop-before{border-top:2px solid var(--accent);}
    .mod.will-drop-after{border-bottom:2px solid var(--accent);}
    .mod-top{display:flex;align-items:center;gap:6px;margin-bottom:8px;}
    .mod-grip{cursor:grab;color:var(--text3);flex-shrink:0;display:none;align-items:center;padding:2px;border-radius:3px;}
    .mod-grip:hover{color:var(--text2);}
    body.drag-mode .mod-grip{display:flex;}
    .mod-lbl-i{flex:1;font-size:12.5px;font-weight:500;color:var(--text);background:transparent;border:1px solid transparent;border-radius:4px;padding:2px 5px;outline:none;transition:all .1s;}
    .mod-lbl-i:hover{background:var(--surface2);border-color:var(--border);}
    .mod-lbl-i:focus{background:var(--surface);border-color:var(--accent);box-shadow:0 0 0 2px var(--accent-soft);}
    .mod-type-tag{font-size:10px;color:var(--text3);background:var(--surface2);border-radius:4px;padding:2px 5px;white-space:nowrap;}
    .ico-btn-sm{width:21px;height:21px;border-radius:4px;border:none;background:transparent;color:var(--text3);cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .1s;}
    .ico-btn-sm:hover{background:var(--surface2);color:var(--text2);}
    .ico-btn-sm.danger:hover{background:var(--red-soft);color:var(--red-c);}

    .entry-row{display:flex;align-items:center;gap:6px;margin-bottom:9px;}
    .entry-lbl{font-size:10px;color:var(--text3);white-space:nowrap;flex-shrink:0;}
    .entry-i{flex:1;height:22px;padding:0 7px;font-size:10.5px;font-family:'SF Mono','Fira Code',monospace;color:var(--text2);background:var(--surface2);border:1px solid var(--border);border-radius:4px;outline:none;}
    .entry-i::placeholder{color:var(--text3);font-style:italic;}
    .entry-i:focus{border-color:var(--accent);box-shadow:0 0 0 2px var(--accent-soft);}

    .ctr-row{display:flex;align-items:center;width:fit-content;}
    .ctr-btn{width:33px;height:33px;font-size:17px;display:flex;align-items:center;justify-content:center;border:1px solid var(--border-strong);background:var(--surface2);color:var(--text);cursor:pointer;transition:background .1s;flex-shrink:0;}
    .ctr-btn:first-child{border-radius:6px 0 0 6px;}.ctr-btn:last-child{border-radius:0 6px 6px 0;}
    .ctr-btn:hover{background:var(--surface3);}
    .ctr-val{width:52px;height:33px;text-align:center;font-size:15px;font-weight:700;border:1px solid var(--border-strong);border-left:none;border-right:none;background:var(--surface3);color:var(--text);outline:none;}
    .sl-row{display:flex;align-items:center;gap:8px;}
    .sl-track{flex:1;}
    input[type=range]{width:100%;accent-color:var(--accent);cursor:pointer;display:block;}
    .sl-val{font-size:14px;font-weight:700;min-width:20px;text-align:right;color:var(--text);}
    .sl-max-wrap{display:flex;align-items:center;gap:3px;flex-shrink:0;}
    .sl-sep{font-size:11px;color:var(--text3);}
    .sl-max-i{width:38px;height:22px;text-align:center;font-size:11px;font-weight:700;border:1px solid var(--border-strong);border-radius:4px;background:var(--surface2);color:var(--text);outline:none;}
    .sl-max-i:focus{border-color:var(--accent);}
    .sl-ends{display:flex;justify-content:space-between;font-size:10px;color:var(--text3);margin-top:2px;}
    .tog-row{display:flex;align-items:center;gap:8px;}
    .tog-sw{position:relative;width:36px;height:19px;flex-shrink:0;}
    .tog-sw input{opacity:0;width:0;height:0;}
    .tog-track{position:absolute;inset:0;background:var(--border-strong);border-radius:9.5px;cursor:pointer;transition:background .18s;}
    .tog-sw input:checked+.tog-track{background:var(--accent);}
    .tog-track::after{content:'';position:absolute;top:2px;left:2px;width:15px;height:15px;background:#fff;border-radius:50%;transition:transform .18s;}
    .tog-sw input:checked+.tog-track::after{transform:translateX(17px);}
    .tog-desc-i{flex:1;font-size:12px;color:var(--text2);background:transparent;border:1px solid transparent;border-radius:4px;padding:2px 5px;outline:none;transition:all .1s;}
    .tog-desc-i::placeholder{color:var(--text3);font-style:italic;}
    .tog-desc-i:hover{background:var(--surface2);border-color:var(--border);}
    .tog-desc-i:focus{background:var(--surface);border-color:var(--accent);}
    .opt-editor{display:flex;flex-direction:column;gap:4px;margin-top:7px;}
    .opt-editor-lbl{font-size:10px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text3);margin-bottom:1px;}
    .opt-row{display:flex;align-items:center;gap:5px;}
    .opt-i{flex:1;height:25px;padding:0 7px;border:1px solid var(--border);border-radius:5px;font-size:12px;color:var(--text);background:var(--surface2);outline:none;}
    .opt-i:focus{border-color:var(--accent);}
    .add-opt-btn{display:flex;align-items:center;gap:4px;font-size:11px;color:var(--text3);background:none;border:none;padding:0;cursor:pointer;}
    .add-opt-btn:hover{color:var(--accent);}
    .mod-sel{height:30px;padding:0 8px;border:1px solid var(--border-strong);border-radius:6px;font-size:12px;color:var(--text);background:var(--surface2);outline:none;width:100%;cursor:pointer;}
    .mod-sel:focus{border-color:var(--accent);}
    .stars-row{display:flex;align-items:center;gap:3px;}
    .star{font-size:21px;cursor:pointer;color:var(--border-strong);line-height:1;transition:all .07s;user-select:none;}
    .star.on{color:#f59e0b;}
    .star-lbl{font-size:11px;color:var(--text3);margin-left:5px;}
    .mod-ta{width:100%;min-height:58px;padding:7px 8px;border:1px solid var(--border-strong);border-radius:6px;font-size:12px;color:var(--text);background:var(--surface2);outline:none;resize:vertical;font-family:inherit;line-height:1.5;}
    .mod-ta:focus{border-color:var(--accent);}

    #pv-overlay{position:fixed;inset:0;z-index:300;background:rgba(0,0,0,.72);display:none;align-items:center;justify-content:center;backdrop-filter:blur(6px);padding:20px;}
    #pv-overlay.open{display:flex;}
    .pv-shell{width:100%;max-width:390px;height:min(750px,calc(100vh - 40px));background:#f2f1ec;border-radius:24px;box-shadow:0 32px 80px rgba(0,0,0,.55);display:flex;flex-direction:column;overflow:hidden;}
    .pv-notch{height:24px;background:rgba(0,0,0,.06);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
    .pv-notch-bar{width:52px;height:4px;background:rgba(0,0,0,.18);border-radius:2px;}
    .pv-hdr{flex-shrink:0;padding:15px 18px 13px;display:flex;flex-direction:column;gap:2px;}
    .pv-hdr.red{background:#c0282e;}.pv-hdr.blue{background:#1b4fcc;}
    .pv-alliance{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.6);}
    .pv-team{font-size:28px;font-weight:800;color:#fff;line-height:1.05;letter-spacing:-.02em;}
    .pv-sub{font-size:12px;color:rgba(255,255,255,.65);margin-top:1px;}
    .pv-body{flex:1;overflow-y:auto;padding:13px 13px 18px;display:flex;flex-direction:column;gap:8px;}
    .pf{background:#fff;border-radius:10px;padding:11px 13px 12px;box-shadow:0 1px 3px rgba(0,0,0,.07);}
    .pf-lbl{font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:#888;margin-bottom:8px;}
    .pf-ctr{display:flex;align-items:center;width:fit-content;}
    .pf-ctr-btn{width:40px;height:40px;font-size:21px;display:flex;align-items:center;justify-content:center;border:1.5px solid #e0e0e0;background:#f7f7f7;color:#1a1918;cursor:pointer;user-select:none;transition:background .1s;}
    .pf-ctr-btn:first-child{border-radius:8px 0 0 8px;}.pf-ctr-btn:last-child{border-radius:0 8px 8px 0;}
    .pf-ctr-btn:active{background:#e5e5e5;}
    .pf-ctr-val{width:62px;height:40px;text-align:center;font-size:20px;font-weight:800;border:1.5px solid #e0e0e0;border-left:none;border-right:none;background:#f2f1ec;color:#1a1918;outline:none;}
    .pf-sl-row{display:flex;align-items:center;gap:9px;}
    .pf-sl-track{flex:1;}
    .pf-sl-track input[type=range]{width:100%;cursor:pointer;display:block;accent-color:#2563eb;}
    .pf-sl-val{font-size:18px;font-weight:800;color:#1a1918;min-width:24px;text-align:right;}
    .pf-sl-ends{display:flex;justify-content:space-between;font-size:10px;color:#aaa;margin-top:3px;}
    .pf-tog-row{display:flex;align-items:center;gap:11px;}
    .pf-tog-sw{position:relative;width:48px;height:27px;flex-shrink:0;}
    .pf-tog-sw input{opacity:0;width:0;height:0;}
    .pf-tog-track{position:absolute;inset:0;background:#ddd;border-radius:13.5px;cursor:pointer;transition:background .18s;}
    .pf-tog-sw input:checked+.pf-tog-track{background:#2563eb;}
    .pf-tog-track::after{content:'';position:absolute;top:3px;left:3px;width:21px;height:21px;background:#fff;border-radius:50%;transition:transform .18s;box-shadow:0 1px 4px rgba(0,0,0,.2);}
    .pf-tog-sw input:checked+.pf-tog-track::after{transform:translateX(21px);}
    .pf-tog-desc{font-size:13px;color:#555;}
    .pf-ckg{display:flex;flex-direction:column;gap:8px;}
    .pf-ckg-item{display:flex;align-items:center;gap:9px;cursor:pointer;user-select:none;}
    .pf-ckg-item input[type=checkbox]{width:18px;height:18px;accent-color:#2563eb;cursor:pointer;flex-shrink:0;}
    .pf-ckg-item span{font-size:13px;color:#1a1918;}
    .pf-sel{width:100%;height:38px;padding:0 10px;border:1.5px solid #e0e0e0;border-radius:8px;font-size:13px;color:#1a1918;background:#f7f7f7;outline:none;cursor:pointer;}
    .pf-sel:focus{border-color:#2563eb;}
    .pf-stars{display:flex;align-items:center;gap:4px;}
    .pf-star{font-size:28px;cursor:pointer;color:#ddd;line-height:1;transition:color .07s;user-select:none;}
    .pf-star.on{color:#f59e0b;}
    .pf-ta{width:100%;min-height:72px;padding:8px 10px;border:1.5px solid #e0e0e0;border-radius:8px;font-size:13px;color:#1a1918;background:#f7f7f7;outline:none;resize:vertical;font-family:inherit;line-height:1.5;}
    .pf-ta:focus{border-color:#2563eb;}
    .pv-footer{flex-shrink:0;padding:8px 13px 13px;display:flex;flex-direction:column;gap:5px;border-top:1px solid rgba(0,0,0,.07);background:#f2f1ec;}
    .pv-footer-row{display:flex;gap:7px;}
    .pv-back{flex:1;height:38px;border-radius:8px;font-size:13px;font-weight:600;border:1.5px solid #ddd;background:#fff;color:#444;cursor:pointer;}
    .pv-submit{flex:2;height:38px;border-radius:8px;font-size:13px;font-weight:800;border:none;color:#fff;cursor:pointer;transition:opacity .1s;}
    .pv-submit.red{background:#c0282e;}.pv-submit.blue{background:#1b4fcc;}
    .pv-submit:hover{opacity:.85;}
    .pv-status{font-size:11px;text-align:center;display:none;}
    .pv-status.ok{display:block;color:#16a34a;}.pv-status.err{display:block;color:#dc2626;}

    ::-webkit-scrollbar{width:5px;}
    ::-webkit-scrollbar-thumb{background:var(--border-strong);border-radius:3px;}
  </style>
</head>
<body>

<div class="topbar">
  <div class="topbar-brand">Scout<span>Master</span></div>
  <div class="tab-strip">
    <div class="tab active" id="tab-schedule" onclick="switchTab('schedule')">
      <span class="tab-dot"></span>Schedule
    </div>
    <div class="tab" id="tab-builder" onclick="switchTab('builder')">
      <span class="tab-dot"></span>Form Builder
      <span class="tab-ct" id="tab-fct">0</span>
    </div>
  </div>
  <div class="topbar-meta" id="topbar-meta">No event loaded</div>
  <div class="topbar-actions">
    <button class="btn" id="preview-btn" onclick="previewForm()" disabled>Preview Form</button>
    <button class="btn accent" id="push-btn" onclick="pushAll()" disabled>↑ Push to Tablets</button>
  </div>
</div>

<div class="layout">
  <aside class="left-panel">
    <div class="lp-sec">
      <div class="lp-ttl">Event Setup</div>
      <div class="lp-f"><div class="lp-lbl">Event Key</div><input class="lp-i" id="event-key" value="2026mibro" placeholder="e.g. 2026mibro" /></div>
      <div class="lp-f"><div class="lp-lbl">Level</div>
        <select class="lp-i" id="comp-level">
          <option value="qm">Quals</option><option value="qf">Quarters</option><option value="sf">Semis</option><option value="f">Finals</option>
        </select>
      </div>
      <div style="margin-top:9px">
        <button class="btn accent" style="width:100%;justify-content:center" id="load-btn" onclick="loadEvent()">Load Event from TBA</button>
      </div>
      <div class="pill" id="pill-load"></div>
    </div>

    <div class="lp-sec">
      <div class="lp-ttl">Current Match</div>
      <div class="match-big">
        <div class="mb-lbl">Now Scouting</div>
        <div class="mb-num" id="mb-num">—</div>
        <div class="mb-sub" id="mb-sub">Load event first</div>
      </div>
      <div class="match-nav">
        <button class="btn" onclick="stepMatch(-1)">← Prev</button>
        <button class="btn green" id="push-match-btn" onclick="pushAll()" disabled>Push Match</button>
        <button class="btn" onclick="stepMatch(1)">Next →</button>
      </div>
      <div class="pill" id="pill-match"></div>
    </div>

    <div class="lp-sec" style="flex:1">
      <div class="lp-ttl">Scouter Positions</div>
      <div class="lnk-list" id="lnk-list"></div>
      <div style="margin-top:9px;font-size:10px;color:var(--text3);line-height:1.75">
        Open <code style="font-size:9.5px;background:var(--surface3);padding:1px 5px;border-radius:3px">scouter.html?pos=red1</code> on each tablet.<br>
        Keys: <strong style="color:var(--text2)">red1 red2 red3 blue1 blue2 blue3</strong>
      </div>
    </div>
  </aside>

  <div class="main-area">
    <div class="tab-panel active" id="panel-schedule">
      <div class="sch-wrap">
        <div class="sch-hdr">
          <span class="sch-title" id="sch-title">Match Schedule</span>
          <span class="sch-meta"  id="sch-meta"></span>
        </div>
        <div id="sch-content">
          <div class="empty-state">
            <div class="empty-icon">📋</div>
            Enter an event key and click <strong>Load Event from TBA</strong>.<br>
            Build your form in the <strong>Form Builder</strong> tab, then<br>
            click <strong>↑ Push to Tablets</strong> to send everything at once.
          </div>
        </div>
      </div>
    </div>

    <div class="tab-panel" id="panel-builder">
      <div class="builder-layout">
        <div class="palette">
          <div class="pal-lbl">Fields</div>
          <button class="pal-btn" onclick="addMod('counter')"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><rect x=".5" y=".5" width="3" height="11" rx="1" stroke="currentColor" stroke-width="1.2"/><rect x="8.5" y=".5" width="3" height="11" rx="1" stroke="currentColor" stroke-width="1.2"/><path d="M3 6h6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>Counter<span class="pal-ct" id="pct-counter">0</span></button>
          <button class="pal-btn" onclick="addMod('slider')"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><line x1="1" y1="6" x2="11" y2="6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><circle cx="6" cy="6" r="2.2" fill="currentColor"/></svg>Slider<span class="pal-ct" id="pct-slider">0</span></button>
          <button class="pal-btn" onclick="addMod('toggle')"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><rect x=".5" y="3.5" width="11" height="5" rx="2.5" stroke="currentColor" stroke-width="1.2"/><circle cx="8.5" cy="6" r="1.6" fill="currentColor"/></svg>Toggle<span class="pal-ct" id="pct-toggle">0</span></button>
          <button class="pal-btn" onclick="addMod('checkgroup')"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><rect x=".5" y=".5" width="4" height="4" rx=".8" stroke="currentColor" stroke-width="1.2"/><rect x=".5" y="7.5" width="4" height="4" rx=".8" stroke="currentColor" stroke-width="1.2"/><line x1="7" y1="2.5" x2="11.5" y2="2.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="7" y1="9.5" x2="11.5" y2="9.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>Checklist<span class="pal-ct" id="pct-checkgroup">0</span></button>
          <button class="pal-btn" onclick="addMod('select')"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><rect x=".5" y="2.5" width="11" height="7" rx="1.6" stroke="currentColor" stroke-width="1.2"/><path d="M7.5 5l1.8 1.8 1.8-1.8" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/></svg>Dropdown<span class="pal-ct" id="pct-select">0</span></button>
          <button class="pal-btn" onclick="addMod('stars')"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M6 1l1.3 2.7 2.9.42-2.1 2.04.5 2.94L6 7.84 4.4 8.6l.5-2.94L2.8 3.62l2.9-.42z" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round"/></svg>Rating<span class="pal-ct" id="pct-stars">0</span></button>
          <button class="pal-btn" onclick="addMod('text')"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M1.5 3h9M1.5 6h6.5M1.5 9h4.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>Notes<span class="pal-ct" id="pct-text">0</span></button>
          <div class="pal-div"></div>
          <div class="pal-lbl">Controls</div>
          <button class="reorder-toggle" id="reorder-toggle" onclick="toggleDragMode()"><span class="rt-dot"></span><span id="rt-lbl">Reorder: Off</span></button>
          <div class="pal-div"></div>
          <div class="pal-lbl">Sync</div>
          <button class="load-form-btn" id="load-form-btn" onclick="loadCurrentForm(false)">
            <svg width="11" height="11" viewBox="0 0 11 11" fill="none">
              <path d="M5.5 1v6M2.5 4.5l3 3 3-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M1 9.5h9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
            Load Saved Form
          </button>
          <div class="schema-status" id="schema-status"></div>
          <div class="pal-div"></div>
          <div class="pal-tip">Each field has an optional <strong>Entry ID</strong> — paste the <code style="font-size:9px;background:var(--surface3);padding:1px 4px;border-radius:3px">entry.XXXXXXX</code> from your Google Form so scouter submissions map correctly.</div>
        </div>

        <div class="canvas-wrap" id="canvas-wrap" ondragover="wrapDragOver(event)" ondragleave="wrapDragLeave(event)" ondrop="wrapDrop(event)">
          <div class="bldr-hdr">
            <span class="bldr-title">Scouting Form Fields</span>
            <span class="bldr-ct" id="canvas-ct">0 fields</span>
          </div>
          <div id="canvas-empty">Click a field type on the left to add it, or drag to reorder once fields are added.</div>
          <div id="canvas"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<div id="pv-overlay">
  <div class="pv-shell">
    <div class="pv-notch"><div class="pv-notch-bar"></div></div>
    <div class="pv-hdr red" id="pv-hdr">
      <div class="pv-alliance" id="pv-alliance">Red 1 · Preview</div>
      <div class="pv-team" id="pv-team">Team —</div>
      <div class="pv-sub"  id="pv-sub">Form Preview</div>
    </div>
    <div class="pv-body" id="pv-body"></div>
    <div class="pv-footer">
      <div class="pv-footer-row">
        <button class="pv-back" onclick="closePv()">← Close</button>
        <button class="pv-submit red" id="pv-submit-btn" onclick="submitPv()">Submit (Preview)</button>
      </div>
      <div class="pv-status" id="pv-status"></div>
    </div>
  </div>
</div>

<script>
'use strict';

const TBA_KEY     = 'eI8ayHzu2uU48kVC3Q2E1TR077j18LyPvIwVwJzlNWnccQllrUdMWLn6d3oLFGM7';
const SCHED_FORM   = 'https://docs.google.com/forms/u/0/d/e/1FAIpQLScMbzZf7quiHuzsZ9MxfiZuFQ78fMK-K6DFqhGbuvL-dCJUZA/formResponse';
const SCHED_ENTRY  = 'entry.2031591481';
const SCHEMA_FORM  = 'https://docs.google.com/forms/u/0/d/e/1FAIpQLSf_YxWuwzmwUH80Rm3Gpq837ZP3dxFKEmr5w_eXf_Nc7cfTUQ/formResponse';
const SCHEMA_ENTRY = 'entry.186049065';
const SCOUT_FORM   = 'https://docs.google.com/forms/u/0/d/e/1FAIpQLSdjJa8vcqlbNuEGW1I_rsNWr-6awrT9bm4IoYjsEwVW26zlJQ/formResponse';
const ENTRY_MATCH  = 'entry.522464042';
const ENTRY_EVENT  = 'entry.964809056';
const SHEET_ID   = '1Fbb-xBJtXzddPdUbVrn78KfamWEw8D578osVgGHolAo';
const SCHEMA_GID = '437577327';

/* ══ TAB ══ */
function switchTab(name) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  document.getElementById('panel-' + name).classList.add('active');
}

/* ══ TBA / SCHEDULE ══ */
let schedule = [], teamCache = {}, currentIdx = 0, eventKey = '', compLevel = 'qm';

async function loadEvent() {
  eventKey  = document.getElementById('event-key').value.trim();
  compLevel = document.getElementById('comp-level').value;
  if (!eventKey) { pill('pill-load','Enter an event key.','err'); return; }
  const btn = document.getElementById('load-btn');
  btn.textContent = 'Loading…'; btn.disabled = true;
  pill('pill-load','Fetching from TBA…','pending');
  try {
    const [mr,tr] = await Promise.all([
      fetch(`https://www.thebluealliance.com/api/v3/event/${eventKey}/matches/simple`,{headers:{'X-TBA-Auth-Key':TBA_KEY}}),
      fetch(`https://www.thebluealliance.com/api/v3/event/${eventKey}/teams`,{headers:{'X-TBA-Auth-Key':TBA_KEY}})
    ]);
    if (!mr.ok) throw new Error('Matches HTTP '+mr.status);
    if (!tr.ok) throw new Error('Teams HTTP '+tr.status);
    const [matches,teams] = await Promise.all([mr.json(),tr.json()]);
    teamCache={};
    teams.forEach(t=>{teamCache[t.key]=t.nickname||'';});
    const filtered = matches.filter(m=>m.comp_level===compLevel).sort((a,b)=>a.match_number-b.match_number);
    if (!filtered.length) throw new Error('No '+compLevel+' matches found.');
    schedule = filtered.map(m=>({
      matchNum: m.match_number,
      red:  m.alliances.red.team_keys.map(k=>k.replace('frc','')),
      blue: m.alliances.blue.team_keys.map(k=>k.replace('frc','')),
      redNames:  m.alliances.red.team_keys.map(k=>teamCache[k]||''),
      blueNames: m.alliances.blue.team_keys.map(k=>teamCache[k]||''),
    }));
    currentIdx=0;
    renderSchedule(); updateMatchDisplay(); updateLinkList();
    document.getElementById('push-btn').disabled       = false;
    document.getElementById('push-match-btn').disabled = false;
    document.getElementById('preview-btn').disabled    = mods.length === 0;
    document.getElementById('topbar-meta').textContent = eventKey.toUpperCase()+' · '+schedule.length+' matches';
    document.getElementById('sch-title').textContent   = 'Match Schedule — '+eventKey.toUpperCase();
    document.getElementById('sch-meta').textContent    = schedule.length+' matches';
    pill('pill-load','✓ '+schedule.length+' matches, '+teams.length+' teams loaded','ok');
  } catch(e) {
    pill('pill-load','Error: '+e.message,'err');
  } finally {
    btn.textContent='Load Event from TBA'; btn.disabled=false;
  }
}

function renderSchedule() {
  if (!schedule.length) return;
  const rows = schedule.map((m,i)=>`
    <tr class="${i===currentIdx?'cur':''}" id="srow-${i}">
      <td class="mn">${m.matchNum}</td>
      <td class="rt">${m.red[0]}<span class="tn">${esc(m.redNames[0])}</span></td>
      <td class="rt">${m.red[1]}<span class="tn">${esc(m.redNames[1])}</span></td>
      <td class="rt">${m.red[2]}<span class="tn">${esc(m.redNames[2])}</span></td>
      <td class="bt">${m.blue[0]}<span class="tn">${esc(m.blueNames[0])}</span></td>
      <td class="bt">${m.blue[1]}<span class="tn">${esc(m.blueNames[1])}</span></td>
      <td class="bt">${m.blue[2]}<span class="tn">${esc(m.blueNames[2])}</span></td>
      <td><button class="go-btn ${i===currentIdx?'cur':''}" onclick="setMatch(${i})">Scout this</button></td>
    </tr>`).join('');
  document.getElementById('sch-content').innerHTML=`<div class="tbl-wrap"><table>
    <thead><tr><th>Match</th><th class="red">Red 1</th><th class="red">Red 2</th><th class="red">Red 3</th><th class="blue">Blue 1</th><th class="blue">Blue 2</th><th class="blue">Blue 3</th><th></th></tr></thead>
    <tbody>${rows}</tbody></table></div>`;
}

function setMatch(idx) {
  currentIdx=idx; renderSchedule(); updateMatchDisplay(); updateLinkList();
  const r=document.getElementById('srow-'+idx); if(r) r.scrollIntoView({behavior:'smooth',block:'nearest'});
}
function stepMatch(d) { if(schedule.length) setMatch(Math.max(0,Math.min(schedule.length-1,currentIdx+d))); }
function updateMatchDisplay() {
  if (!schedule.length) { document.getElementById('mb-num').textContent='—'; document.getElementById('mb-sub').textContent='Load event first'; return; }
  const m=schedule[currentIdx];
  document.getElementById('mb-num').textContent=m.matchNum;
  document.getElementById('mb-sub').textContent=eventKey.toUpperCase()+' · '+(currentIdx+1)+' of '+schedule.length;
}

const POS_KEYS=['red1','red2','red3','blue1','blue2','blue3'];
const POS_LABELS=['Red 1','Red 2','Red 3','Blue 1','Blue 2','Blue 3'];
const POS_ALS=[  'red','red','red','blue','blue','blue'];
const POS_IDX=[   0,    1,    2,    0,     1,     2   ];

function updateLinkList() {
  document.getElementById('lnk-list').innerHTML=POS_KEYS.map((key,i)=>{
    const al=POS_ALS[i],idx=POS_IDX[i],m=schedule[currentIdx];
    const team=m?m[al][idx]:'—', name=m?m[al+'Names'][idx]:'';
    return `<div class="lnk-row">
      <span class="al-badge ${al}">${POS_LABELS[i]}</span>
      <span class="lnk-team">${team}</span>
      <span class="lnk-name">${esc(name)}</span>
      <button class="ico-btn" title="Open scouter in new tab" onclick="openScouter('${key}')">
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M4.5 1H1v8h8V5.5M6 1h3m0 0v3m0-3L4.5 5.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="ico-btn" title="Copy link" onclick="copyScouterLink('scouter.html?pos=${key}',this)">
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><rect x="3" y="3" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.2"/><path d="M1 7V1h6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
      </button>
    </div>`;
  }).join('');
}

async function copyScouterLink(path,btn){
  const full=window.location.href.replace(/[^/]*$/,'')+path;
  try{await navigator.clipboard.writeText(full);}catch(e){}
  btn.style.color='#22c55e'; setTimeout(()=>{btn.style.color='';},1400);
}

/* ══ Open scouter.html in a new tab ══ */
/* ══ EMBEDDED SCOUTER LAUNCHER ══
   The scouter HTML is embedded as base64 with a __POS__ placeholder.
   We swap the placeholder before creating the blob so the page knows
   which alliance position it is — no external file needed.
══ */
const _SCOUTER_B64 = '';

function openScouter(posKey) {
  // Decode base64 → swap __POS__ placeholder → blob URL → new tab
  const raw   = atob(_SCOUTER_B64);
  const html  = raw.replace('__POS__', posKey.toLowerCase());
  const bytes = new Uint8Array(html.length);
  for (let i = 0; i < html.length; i++) bytes[i] = html.charCodeAt(i);
  const url = URL.createObjectURL(new Blob([bytes], { type: 'text/html' }));
  window.open(url, '_blank');
}

/* ══ LOAD SAVED FORM FROM SHEET ══ */
async function loadCurrentForm(silent = false) {
  const btn = document.getElementById('load-form-btn');
  const st  = document.getElementById('schema-status');
  btn.disabled = true;
  if (!silent) { st.textContent = 'Fetching saved form…'; st.className = 'schema-status pending'; }
  try {
    const res = await fetch(
      `https://docs.google.com/spreadsheets/d/${SHEET_ID}/export?format=csv&gid=${SCHEMA_GID}&t=${Date.now()}`
    );
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const csv  = await res.text();
    const cell = csvFirstCell(csv);
    if (!cell || !cell.startsWith('{')) throw new Error('No saved form found in sheet.');
    const parsed = JSON.parse(cell);
    const fields = parsed.fields || [];
    if (!fields.length) throw new Error('Saved form has no fields.');
    if (!silent && mods.length > 0) {
      const ok = confirm(
        `Replace ${mods.length} current field${mods.length !== 1 ? 's' : ''} with the ${fields.length} saved field${fields.length !== 1 ? 's' : ''} from your last push?\n\nThis loads your live form into the editor so you can tweak it.`
      );
      if (!ok) { btn.disabled = false; st.className = 'schema-status'; return; }
    }
    mods = fields.map(f => ({ id: f.id || uid(), ...f }));
    renderAll();
    document.getElementById('preview-btn').disabled = false;
    st.textContent = `✓ Loaded ${mods.length} field${mods.length !== 1 ? 's' : ''} from last push`;
    st.className = 'schema-status ok';
  } catch (e) {
    if (!silent) { st.textContent = 'Load failed: ' + e.message; st.className = 'schema-status err'; }
  } finally {
    btn.disabled = false;
  }
}

function csvFirstCell(text) {
  let s = '', inQ = false;
  for (let i = 0; i < text.length; i++) {
    const c = text[i];
    if (c === '"') {
      if (inQ && text[i + 1] === '"') { s += '"'; i++; }
      else inQ = !inQ;
    } else if ((c === ',' || c === '\n' || c === '\r') && !inQ) {
      break;
    } else { s += c; }
  }
  return s.trim();
}

/* ══ FORM BUILDER ══ */
let mods=[], dragMode=false, modDragId=null;
const DEFAULTS={
  counter:    ()=>({label:'Game Pieces Scored',value:0,min:0,max:99,step:1,entry:''}),
  slider:     ()=>({label:'Defense Rating',value:5,min:0,max:10,step:1,minLabel:'None',maxLabel:'Elite',entry:''}),
  toggle:     ()=>({label:'Broke Down',value:false,desc:'',entry:''}),
  checkgroup: ()=>({label:'Capabilities',options:[],checked:[],entry:''}),
  select:     ()=>({label:'Endgame Status',options:[],value:'',entry:''}),
  stars:      ()=>({label:'Overall Rating',value:0,max:5,entry:''}),
  text:       ()=>({label:'Notes',value:'',entry:''}),
};
const TYPE_NAMES={counter:'Counter',slider:'Slider',toggle:'Toggle',checkgroup:'Checklist',select:'Dropdown',stars:'Rating',text:'Notes'};
function uid(){return Math.random().toString(36).slice(2,9);}
function getMod(id){return mods.find(m=>m.id===id);}
function clamp(v,mn,mx){return Math.min(mx,Math.max(mn,v));}

function addMod(type,insertIdx=-1){
  const m={id:uid(),type,...DEFAULTS[type]()};
  if(insertIdx<0||insertIdx>=mods.length) mods.push(m); else mods.splice(insertIdx,0,m);
  renderAll();
  requestAnimationFrame(()=>{const el=document.querySelector(`.mod[data-id="${m.id}"]`);if(el)el.scrollIntoView({behavior:'smooth',block:'nearest'});});
}
function dupMod(id){
  const src=getMod(id),copy=JSON.parse(JSON.stringify(src));
  copy.id=uid(); mods.splice(mods.findIndex(m=>m.id===id)+1,0,copy); renderAll();
}
function delMod(id){mods=mods.filter(m=>m.id!==id);renderAll();}

function renderAll(){
  const canvas=document.getElementById('canvas'),empty=document.getElementById('canvas-empty');
  const ct={};
  mods.forEach(m=>{ct[m.type]=(ct[m.type]||0)+1;});
  Object.keys(DEFAULTS).forEach(t=>{const e=document.getElementById('pct-'+t);if(e)e.textContent=ct[t]||0;});
  const total=mods.length;
  document.getElementById('canvas-ct').textContent=total+' field'+(total!==1?'s':'');
  document.getElementById('tab-fct').textContent=total;
  empty.style.display=total===0?'':'none';
  const existing={};
  canvas.querySelectorAll('.mod').forEach(el=>{existing[el.dataset.id]=el;});
  Object.keys(existing).forEach(id=>{if(!mods.find(m=>m.id===id))existing[id].remove();});
  mods.forEach((m,i)=>{
    let card=existing[m.id];
    if(!card){card=buildCard(m);}
    else{const b=card.querySelector('.mod-body');if(b)b.innerHTML=buildWidget(m);}
    const cur=canvas.children[i];if(cur!==card)canvas.insertBefore(card,cur||null);
  });
}

function buildCard(m){
  const d=document.createElement('div');
  d.className='mod'; d.dataset.id=m.id; d.draggable=dragMode;
  d.innerHTML=`
    <div class="mod-top">
      <span class="mod-grip"><svg width="8" height="12" viewBox="0 0 8 12" fill="none"><circle cx="2" cy="2" r="1" fill="currentColor"/><circle cx="6" cy="2" r="1" fill="currentColor"/><circle cx="2" cy="6" r="1" fill="currentColor"/><circle cx="6" cy="6" r="1" fill="currentColor"/><circle cx="2" cy="10" r="1" fill="currentColor"/><circle cx="6" cy="10" r="1" fill="currentColor"/></svg></span>
      <input class="mod-lbl-i" value="${esc(m.label)}" placeholder="Field label" />
      <span class="mod-type-tag">${TYPE_NAMES[m.type]}</span>
      <button class="ico-btn-sm" title="Duplicate" onclick="dupMod('${m.id}')"><svg width="11" height="11" viewBox="0 0 11 11" fill="none"><rect x="3" y="3" width="7" height="7" rx="1.2" stroke="currentColor" stroke-width="1.2"/><path d="M1 8V1h7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg></button>
      <button class="ico-btn-sm danger" title="Delete" onclick="delMod('${m.id}')"><svg width="9" height="9" viewBox="0 0 9 9" fill="none"><path d="M1 1l7 7M8 1L1 8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg></button>
    </div>
    <div class="entry-row">
      <span class="entry-lbl">Entry ID:</span>
      <input class="entry-i" value="${esc(m.entry||'')}" placeholder="entry.XXXXXXX  (optional — maps to Google Form field)" />
    </div>
    <div class="mod-body">${buildWidget(m)}</div>`;
  d.querySelector('.mod-lbl-i').addEventListener('input',e=>{m.label=e.target.value;});
  d.querySelector('.entry-i').addEventListener('input',e=>{m.entry=e.target.value.trim();});
  d.addEventListener('dragstart',onModDragStart);
  d.addEventListener('dragend',  onModDragEnd);
  d.addEventListener('dragover', onModDragOver);
  d.addEventListener('dragleave',onModDragLeave);
  d.addEventListener('drop',     onModDrop);
  return d;
}

function buildWidget(m){
  const id=m.id;
  switch(m.type){
    case 'counter':
      return `<div class="ctr-row"><button class="ctr-btn" onclick="ctrStep('${id}',-1)">−</button><input class="ctr-val" type="number" id="cv-${id}" value="${m.value}" oninput="ctrInput('${id}',this.value)"/><button class="ctr-btn" onclick="ctrStep('${id}',1)">+</button></div>`;
    case 'slider':
      return `<div><div class="sl-row"><div class="sl-track"><input type="range" min="${m.min}" max="${m.max}" step="${m.step}" value="${m.value}" oninput="slInput('${id}',this.value)"/></div><span class="sl-val" id="slv-${id}">${m.value}</span><div class="sl-max-wrap"><span class="sl-sep">/</span><input class="sl-max-i" type="number" value="${m.max}" min="1" oninput="slMaxInput('${id}',this.value)"/></div></div><div class="sl-ends"><span>${esc(m.minLabel)}</span><span>${esc(m.maxLabel)}</span></div></div>`;
    case 'toggle':
      return `<div class="tog-row"><label class="tog-sw"><input type="checkbox" ${m.value?'checked':''} onchange="toggleInput('${id}',this.checked)"/><span class="tog-track"></span></label><input class="tog-desc-i" value="${esc(m.desc)}" placeholder="Describe this toggle…" oninput="toggleDesc('${id}',this.value)"/></div>`;
    case 'checkgroup':{
      const rows=m.options.map((o,i)=>`<div class="opt-row"><input type="checkbox" style="width:13px;height:13px;accent-color:var(--accent);flex-shrink:0;cursor:pointer" ${m.checked.includes(o)?'checked':''} onchange="ckgCheck('${id}','${ha(o)}',this.checked)"/><input class="opt-i" value="${esc(o)}" oninput="ckgRename('${id}',${i},this.value)"/><button class="ico-btn-sm danger" onclick="ckgDel('${id}',${i})"><svg width="8" height="8" viewBox="0 0 8 8" fill="none"><path d="M1 1l6 6M7 1L1 7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></button></div>`).join('');
      return `<div class="opt-editor">${m.options.length===0?`<div style="font-size:11px;color:var(--text3)">No options yet.</div>`:rows}<button class="add-opt-btn" onclick="ckgAddOpt('${id}')"><svg width="9" height="9" viewBox="0 0 9 9" fill="none"><path d="M4.5 1v7M1 4.5h7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg> Add option</button></div>`;
    }
    case 'select':{
      const cv=m.options.includes(m.value)?m.value:(m.options[0]||'');
      const opts=m.options.map(o=>`<option ${cv===o?'selected':''}>${esc(o)}</option>`).join('');
      const rows=m.options.map((o,i)=>`<div class="opt-row"><input class="opt-i" value="${esc(o)}" oninput="selEdit('${id}',${i},this.value)"/><button class="ico-btn-sm danger" onclick="selDel('${id}',${i})"><svg width="8" height="8" viewBox="0 0 8 8" fill="none"><path d="M1 1l6 6M7 1L1 7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></button></div>`).join('');
      return `${m.options.length===0?`<div style="font-size:11px;color:var(--text3);margin-bottom:5px">No options yet.</div>`:`<select class="mod-sel" id="sel-${id}" onchange="selInput('${id}',this.value)">${opts}</select>`}<div class="opt-editor"><div class="opt-editor-lbl">Options</div>${rows}<button class="add-opt-btn" onclick="selAddOpt('${id}')"><svg width="9" height="9" viewBox="0 0 9 9" fill="none"><path d="M4.5 1v7M1 4.5h7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg> Add option</button></div>`;
    }
    case 'stars':{
      const stars=Array.from({length:m.max},(_,i)=>`<span class="star ${i<m.value?'on':''}" onclick="starsClick('${id}',${i+1})" onmouseover="starsHov('${id}',${i+1})" onmouseleave="starsUnhov('${id}')">★</span>`).join('');
      return `<div class="stars-row" id="str-${id}">${stars}<span class="star-lbl" id="stl-${id}">${m.value?m.value+'/'+m.max:'No rating'}</span></div>`;
    }
    case 'text':
      return `<textarea class="mod-ta" placeholder="Notes preview…" oninput="textInput('${id}',this.value)">${esc(m.value)}</textarea>`;
  }
  return '';
}

function ctrStep(id,d){const m=getMod(id);m.value=clamp(m.value+d,m.min,m.max);const e=document.getElementById('cv-'+id);if(e)e.value=m.value;}
function ctrInput(id,v){const m=getMod(id);m.value=clamp(parseInt(v)||0,m.min,m.max);}
function slInput(id,v){const m=getMod(id);m.value=parseFloat(v);const e=document.getElementById('slv-'+id);if(e)e.textContent=m.value;}
function slMaxInput(id,v){
  const m=getMod(id);m.max=Math.max(1,parseInt(v)||1);if(m.value>m.max)m.value=m.max;
  const card=document.querySelector(`.mod[data-id="${id}"]`);
  if(card){const r=card.querySelector('input[type=range]');if(r){r.max=m.max;r.value=m.value;}const dv=document.getElementById('slv-'+id);if(dv)dv.textContent=m.value;}
}
function toggleInput(id,v){getMod(id).value=v;}
function toggleDesc(id,v){getMod(id).desc=v;}
function ckgCheck(id,opt,checked){const m=getMod(id);if(checked){if(!m.checked.includes(opt))m.checked.push(opt);}else{m.checked=m.checked.filter(o=>o!==opt);}}
function ckgRename(id,idx,nv){const m=getMod(id);const old=m.options[idx];m.options[idx]=nv;const ci=m.checked.indexOf(old);if(ci!==-1)m.checked[ci]=nv;}
function ckgDel(id,idx){const m=getMod(id);m.checked=m.checked.filter(o=>o!==m.options.splice(idx,1)[0]);renderAll();}
function ckgAddOpt(id){getMod(id).options.push('');renderAll();requestAnimationFrame(()=>{const c=document.querySelector(`.mod[data-id="${id}"]`);if(c){const ins=c.querySelectorAll('.opt-i');const l=ins[ins.length-1];if(l)l.focus();}});}
function selInput(id,v){getMod(id).value=v;}
function selEdit(id,idx,nv){const m=getMod(id);const was=m.value===m.options[idx];m.options[idx]=nv;if(was)m.value=nv;const s=document.getElementById('sel-'+id);if(s&&s.options[idx]){s.options[idx].text=nv;s.options[idx].value=nv;}}
function selDel(id,idx){const m=getMod(id);const r=m.options.splice(idx,1)[0];if(m.value===r)m.value=m.options[0]||'';renderAll();}
function selAddOpt(id){const m=getMod(id);m.options.push('');if(!m.value)m.value='';renderAll();requestAnimationFrame(()=>{const c=document.querySelector(`.mod[data-id="${id}"]`);if(c){const ins=c.querySelectorAll('.opt-i');const l=ins[ins.length-1];if(l)l.focus();}});}
function starsClick(id,n){const m=getMod(id);m.value=m.value===n?0:n;starsRefresh(id);}
function starsHov(id,n){document.getElementById('str-'+id).querySelectorAll('.star').forEach((s,i)=>s.classList.toggle('on',i<n));}
function starsUnhov(id){starsRefresh(id);}
function starsRefresh(id){const m=getMod(id);document.getElementById('str-'+id).querySelectorAll('.star').forEach((s,i)=>s.classList.toggle('on',i<m.value));document.getElementById('stl-'+id).textContent=m.value?m.value+'/'+m.max:'No rating';}
function textInput(id,v){getMod(id).value=v;}

function toggleDragMode(){
  dragMode=!dragMode; document.body.classList.toggle('drag-mode',dragMode);
  const b=document.getElementById('reorder-toggle');b.classList.toggle('on',dragMode);
  document.getElementById('rt-lbl').textContent=dragMode?'Reorder: On':'Reorder: Off';
  document.querySelectorAll('.mod').forEach(el=>{el.draggable=dragMode;});
}
function onModDragStart(evt){if(!dragMode){evt.preventDefault();return;}modDragId=this.dataset.id;evt.dataTransfer.effectAllowed='move';evt.stopPropagation();const s=this;setTimeout(()=>s.classList.add('is-dragging'),0);}
function onModDragEnd(){this.classList.remove('is-dragging');modDragId=null;clearDropHi();}
function onModDragOver(evt){evt.preventDefault();evt.stopPropagation();if(modDragId===this.dataset.id)return;const r=this.getBoundingClientRect();clearDropHi();this.classList.add(evt.clientY<r.top+r.height/2?'will-drop-before':'will-drop-after');evt.dataTransfer.dropEffect='move';}
function onModDragLeave(evt){if(!this.contains(evt.relatedTarget))this.classList.remove('will-drop-before','will-drop-after');}
function onModDrop(evt){
  evt.preventDefault();evt.stopPropagation();
  const tid=this.dataset.id,tidx=mods.findIndex(m=>m.id===tid),r=this.getBoundingClientRect(),before=evt.clientY<r.top+r.height/2,ins=before?tidx:tidx+1;
  if(modDragId&&modDragId!==tid){const si=mods.findIndex(m=>m.id===modDragId);const[mv]=mods.splice(si,1);mods.splice(ins>si?ins-1:ins,0,mv);modDragId=null;renderAll();}
  clearDropHi();
}
function wrapDragOver(evt){evt.preventDefault();if(!evt.target.closest('.mod'))document.getElementById('canvas-empty').classList.add('drag-hi');}
function wrapDragLeave(evt){const w=document.getElementById('canvas-wrap');if(!w.contains(evt.relatedTarget))document.getElementById('canvas-empty').classList.remove('drag-hi');}
function wrapDrop(evt){
  evt.preventDefault();document.getElementById('canvas-empty').classList.remove('drag-hi');
  if(evt.target.closest('.mod'))return;
  if(modDragId){const si=mods.findIndex(m=>m.id===modDragId);const[mv]=mods.splice(si,1);mods.push(mv);modDragId=null;renderAll();}
  clearDropHi();
}
function clearDropHi(){document.querySelectorAll('.mod.will-drop-before,.mod.will-drop-after').forEach(el=>el.classList.remove('will-drop-before','will-drop-after'));const ce=document.getElementById('canvas-empty');if(ce)ce.classList.remove('drag-hi');}

/* ══ PREVIEW ══ */
let pvData={};
function previewForm(){
  if(!mods.length){alert('Add at least one field first.');return;}
  pvData={};
  mods.forEach(m=>{
    switch(m.type){
      case 'counter':case 'stars':pvData[m.id]=m.value;break;
      case 'slider':pvData[m.id]=m.value;break;
      case 'toggle':pvData[m.id]=m.value;break;
      case 'checkgroup':pvData[m.id]=[...m.checked];break;
      case 'select':pvData[m.id]=m.value||(m.options[0]||'');break;
      case 'text':pvData[m.id]=m.value;break;
    }
  });
  const al='red', m=schedule[currentIdx];
  document.getElementById('pv-hdr').className='pv-hdr '+al;
  document.getElementById('pv-alliance').textContent='Red 1 · Preview';
  document.getElementById('pv-team').textContent=m?'Team '+(m.red[0]||'—'):'Team —';
  document.getElementById('pv-sub').textContent=m?eventKey.toUpperCase()+' · Match '+m.matchNum:'Form Preview';
  document.getElementById('pv-submit-btn').className='pv-submit '+al;
  document.getElementById('pv-status').className='pv-status';
  document.getElementById('pv-body').innerHTML=mods.map(m=>buildPvField(m)).join('');
  document.getElementById('pv-overlay').classList.add('open');
}
function closePv(){document.getElementById('pv-overlay').classList.remove('open');}
function submitPv(){
  const st=document.getElementById('pv-status');
  st.textContent='✓ Preview only — no data submitted.';st.className='pv-status ok';
  setTimeout(closePv,1500);
}
function buildPvField(m){
  const v=pvData[m.id];let w='';
  switch(m.type){
    case 'counter':w=`<div class="pf-ctr"><div class="pf-ctr-btn" onclick="pvCtr('${m.id}',-1)">−</div><input class="pf-ctr-val" id="pv-${m.id}" type="number" value="${v}" oninput="pvData['${m.id}']=parseInt(this.value)||0"/><div class="pf-ctr-btn" onclick="pvCtr('${m.id}',1)">+</div></div>`;break;
    case 'slider':w=`<div><div class="pf-sl-row"><div class="pf-sl-track"><input type="range" min="${m.min}" max="${m.max}" value="${v}" oninput="pvData['${m.id}']=parseFloat(this.value);document.getElementById('pvv-${m.id}').textContent=this.value" style="accent-color:#2563eb"/></div><span class="pf-sl-val" id="pvv-${m.id}">${v}</span></div><div class="pf-sl-ends"><span>${esc(m.minLabel||'')}</span><span>${esc(m.maxLabel||'')}</span></div></div>`;break;
    case 'toggle':w=`<div class="pf-tog-row"><label class="pf-tog-sw"><input type="checkbox" ${v?'checked':''} onchange="pvData['${m.id}']=this.checked"/><span class="pf-tog-track"></span></label><span class="pf-tog-desc">${esc(m.desc)||'<span style="color:#bbb;font-style:italic">No description</span>'}</span></div>`;break;
    case 'checkgroup':
      if(!m.options.length){w=`<div style="font-size:12px;color:#bbb;font-style:italic">No options.</div>`;break;}
      w=`<div class="pf-ckg">${m.options.map(o=>`<label class="pf-ckg-item"><input type="checkbox" ${v.includes(o)?'checked':''} onchange="pvCkg('${m.id}','${ha(o)}',this.checked)"/><span>${esc(o)}</span></label>`).join('')}</div>`;break;
    case 'select':
      if(!m.options.length){w=`<div style="font-size:12px;color:#bbb;font-style:italic">No options.</div>`;break;}
      w=`<select class="pf-sel" onchange="pvData['${m.id}']=this.value">${m.options.map(o=>`<option ${v===o?'selected':''}>${esc(o)}</option>`).join('')}</select>`;break;
    case 'stars':w=`<div class="pf-stars" id="pv-${m.id}">${Array.from({length:m.max},(_,i)=>`<span class="pf-star ${i<v?'on':''}" onclick="pvStar('${m.id}',${i+1})" onmouseover="pvStarHov('${m.id}',${i+1})" onmouseleave="pvStarUnhov('${m.id}')">★</span>`).join('')}</div>`;break;
    case 'text':w=`<textarea class="pf-ta" placeholder="Notes…" oninput="pvData['${m.id}']=this.value">${esc(v)}</textarea>`;break;
  }
  return `<div class="pf"><div class="pf-lbl">${esc(m.label||m.type)}</div>${w}</div>`;
}
function pvCtr(id,d){const m=getMod(id);pvData[id]=clamp((pvData[id]||0)+d,m.min,m.max);const e=document.getElementById('pv-'+id);if(e)e.value=pvData[id];}
function pvCkg(id,opt,checked){if(!Array.isArray(pvData[id]))pvData[id]=[];if(checked){if(!pvData[id].includes(opt))pvData[id].push(opt);}else{pvData[id]=pvData[id].filter(o=>o!==opt);}}
function pvStar(id,n){pvData[id]=pvData[id]===n?0:n;pvStarRefresh(id);}
function pvStarHov(id,n){document.getElementById('pv-'+id).querySelectorAll('.pf-star').forEach((s,i)=>s.classList.toggle('on',i<n));}
function pvStarUnhov(id){pvStarRefresh(id);}
function pvStarRefresh(id){const v=pvData[id]||0;const c=document.getElementById('pv-'+id);if(c)c.querySelectorAll('.pf-star').forEach((s,i)=>s.classList.toggle('on',i<v));}

/* ══ PUSH ══ */
function buildSchedPayload(){
  return JSON.stringify({
    v:2, event_key:eventKey,
    current_match: schedule.length ? schedule[currentIdx].matchNum : null,
    schedule: schedule.map(m=>({matchNum:m.matchNum,red:m.red,blue:m.blue,redNames:m.redNames,blueNames:m.blueNames}))
  });
}
function buildSchemaPayload(){
  return JSON.stringify({
    v:2,
    fields: mods.map(m=>{
      const s=JSON.parse(JSON.stringify(m));
      s.value=DEFAULTS[m.type]().value;
      if(s.checked) s.checked=[];
      return s;
    })
  });
}
async function postForm(url,...kvPairs){
  const body=new URLSearchParams();
  for(let i=0;i<kvPairs.length;i+=2) body.set(kvPairs[i],kvPairs[i+1]);
  await fetch(url,{method:'POST',mode:'no-cors',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:body.toString()});
}
async function pushAll(){
  if(!schedule.length){pill('pill-match','Load an event first.','err');return;}
  const pb=document.getElementById('push-btn'),mb=document.getElementById('push-match-btn');
  pb.disabled=mb.disabled=true; pb.textContent='Pushing…';
  pill('pill-match','Pushing schedule + form schema to tablets…','pending');
  try{
    await Promise.all([
      postForm(SCHED_FORM,  SCHED_ENTRY,  buildSchedPayload()),
      postForm(SCHEMA_FORM, SCHEMA_ENTRY, buildSchemaPayload()),
      postForm(SCOUT_FORM, ENTRY_MATCH, String(schedule[currentIdx].matchNum), ENTRY_EVENT, eventKey),
    ]);
    const m=schedule[currentIdx];
    pill('pill-match',`✓ Match ${m.matchNum} · ${mods.length} field${mods.length!==1?'s':''} pushed · Red: ${m.red.join(', ')} · Blue: ${m.blue.join(', ')}`,'ok');
    document.getElementById('topbar-meta').textContent=`Pushed · ${eventKey.toUpperCase()} · Match ${m.matchNum} · ${mods.length} fields`;
    const ss=document.getElementById('schema-status');
    ss.textContent=`✓ Pushed ${mods.length} field${mods.length!==1?'s':''} — form is live on tablets`;
    ss.className='schema-status ok';
  }catch(e){
    pill('pill-match','Push failed — check connection.','err');
  }finally{
    pb.disabled=mb.disabled=false; pb.textContent='↑ Push to Tablets';
  }
}

function pill(id,msg,type){const e=document.getElementById(id);e.textContent=msg;e.className='pill '+type;}
function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function ha(s){return String(s||'').replace(/\\/g,'\\\\').replace(/'/g,"\\'");}

/* ══ INIT ══ */
updateLinkList();
renderAll();
window.onload = () => {
  loadEvent();
  loadCurrentForm(true);
};
</script>
</body>
</html>
